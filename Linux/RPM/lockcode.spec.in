Name:           lockcode-linux
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Protección de privacidad de aplicaciones
License:        LicenseRef-LockCode-Freeware
URL:            https://github.com/D1abloo/LockAPP
Source0:        %{name}-%{version}.tar.gz
BuildArch:      noarch

Requires:       python3
Requires:       python3-gobject
Requires:       gtk3
Requires:       libsecret
Requires:       fprintd
Requires:       polkit
Requires:       dnf
Requires:       libayatana-appindicator-gtk3
Recommends:     gnome-shell-extension-appindicator

%description
LockCode oculta y pausa aplicaciones seleccionadas hasta autenticación mediante
código o huella. Es una protección de privacidad best effort.

%prep
%setup -q

%build

%install
install -d %{buildroot}/usr/lib/lockcode %{buildroot}/usr/bin
install -d %{buildroot}/usr/share/applications %{buildroot}/usr/share/icons/hicolor/scalable/apps
install -d %{buildroot}/usr/lib/systemd/user
cp -a lockcode %{buildroot}/usr/lib/lockcode/
install -m 755 lockcode.py %{buildroot}/usr/lib/lockcode/lockcode.py
ln -s ../lib/lockcode/lockcode.py %{buildroot}/usr/bin/lockcode
install -m 644 assets/com.lockcode.Linux.desktop %{buildroot}/usr/share/applications/
install -m 644 assets/com.lockcode.Linux.svg %{buildroot}/usr/share/icons/hicolor/scalable/apps/
install -m 644 assets/lockcode.service %{buildroot}/usr/lib/systemd/user/

%check
python3 -m compileall -q lockcode

%post
gtk-update-icon-cache -q /usr/share/icons/hicolor >/dev/null 2>&1 || :
update-desktop-database -q /usr/share/applications >/dev/null 2>&1 || :
user="${SUDO_USER:-}"
if [ -z "$user" ] && command -v loginctl >/dev/null 2>&1; then
  user="$(loginctl list-sessions --no-legend 2>/dev/null | awk '$3 != "root" {print $3; exit}')"
fi
if [ -n "$user" ]; then
  uid="$(id -u "$user")"
  home="$(getent passwd "$user" | cut -d: -f6)"
  session="runuser -u $user -- env XDG_RUNTIME_DIR=/run/user/$uid DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$uid/bus"
  $session systemctl --user daemon-reload >/dev/null 2>&1 || :
  $session systemctl --user reenable lockcode.service >/dev/null 2>&1 || :
  if [ "$1" -gt 1 ]; then
    install -d -m 700 -o "$user" -g "$(id -gn "$user")" "$home/.config/lockcode"
    printf 'unknown\n' > "$home/.config/lockcode/update-complete"
    chown "$user:$(id -gn "$user")" "$home/.config/lockcode/update-complete"
    chmod 600 "$home/.config/lockcode/update-complete"
    $session systemd-run --user --quiet --collect --on-active=1s --timer-property=AccuracySec=500ms \
      --unit="lockcode-update-restart-$$" /usr/bin/systemctl --user restart lockcode.service \
      >/dev/null 2>&1 || :
  else
    $session systemctl --user start lockcode.service >/dev/null 2>&1 || :
  fi
fi

%preun
if [ "$1" -eq 0 ]; then
  user="${SUDO_USER:-}"
  if [ -z "$user" ] && command -v loginctl >/dev/null 2>&1; then
    user="$(loginctl list-sessions --no-legend 2>/dev/null | awk '$3 != "root" {print $3; exit}')"
  fi
  if [ -n "$user" ]; then
    uid="$(id -u "$user")"
    runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" \
      DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
      systemctl --user disable --now lockcode.service >/dev/null 2>&1 || :
  fi
fi

%postun
if [ "$1" -eq 0 ]; then
  user="${SUDO_USER:-}"
  if [ -z "$user" ] && command -v loginctl >/dev/null 2>&1; then
    user="$(loginctl list-sessions --no-legend 2>/dev/null | awk '$3 != "root" {print $3; exit}')"
  fi
  if [ -n "$user" ]; then
    home="$(getent passwd "$user" | cut -d: -f6)"
    rm -rf -- "$home/.config/lockcode" "$home/.local/state/lockcode" "$home/.cache/lockcode"
    rm -f -- "$home/.config/autostart/lockcode.desktop"
  fi
fi
gtk-update-icon-cache -q /usr/share/icons/hicolor >/dev/null 2>&1 || :
update-desktop-database -q /usr/share/applications >/dev/null 2>&1 || :

%files
/usr/bin/lockcode
/usr/lib/lockcode
/usr/lib/systemd/user/lockcode.service
/usr/share/applications/com.lockcode.Linux.desktop
/usr/share/icons/hicolor/scalable/apps/com.lockcode.Linux.svg

%changelog
* Wed Jul 15 2026 Isaac Silva Jiménez <kin_coriano14@hotmail.com> - @VERSION@-1
- Primer paquete RPM independiente para Fedora y CentOS Stream.
