#!/bin/sh
set -e
gtk-update-icon-cache -q /usr/share/icons/hicolor 2>/dev/null || true
user="${SUDO_USER:-}"
if [ -z "$user" ] && [ -n "${PKEXEC_UID:-}" ] && [ "$PKEXEC_UID" != "0" ]; then
  user="$(id -nu "$PKEXEC_UID" 2>/dev/null || true)"
fi
if [ -z "$user" ] && command -v loginctl >/dev/null 2>&1; then
  user="$(loginctl list-sessions --no-legend 2>/dev/null | awk '$3 != "root" {print $3; exit}')"
fi
if [ -n "$user" ] && command -v runuser >/dev/null 2>&1; then
  uid="$(id -u "$user")"
  home="$(getent passwd "$user" | cut -d: -f6)"
  rm -f "$home/.config/autostart/lockcode.desktop"
  runuser -u "$user" -- env \
    XDG_RUNTIME_DIR="/run/user/$uid" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
    systemctl --user daemon-reload 2>/dev/null || true
  runuser -u "$user" -- env \
    XDG_RUNTIME_DIR="/run/user/$uid" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
    systemctl --user reenable lockcode.service 2>/dev/null || true
  if [ -n "${2:-}" ]; then
    install -d -m 700 -o "$user" -g "$(id -gn "$user")" "$home/.config/lockcode"
    printf '%s\n' "$2" > "$home/.config/lockcode/update-complete"
    chown "$user:$(id -gn "$user")" "$home/.config/lockcode/update-complete"
    chmod 600 "$home/.config/lockcode/update-complete"
    runuser -u "$user" -- env \
      XDG_RUNTIME_DIR="/run/user/$uid" \
      DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
      systemd-run --user --quiet --collect --on-active=1s --timer-property=AccuracySec=500ms \
        --unit="lockcode-update-restart-$$" /usr/bin/systemctl --user restart lockcode.service \
        2>/dev/null || true
  else
    runuser -u "$user" -- env \
      XDG_RUNTIME_DIR="/run/user/$uid" \
      DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
      systemctl --user start lockcode.service 2>/dev/null || true
  fi
fi
exit 0
