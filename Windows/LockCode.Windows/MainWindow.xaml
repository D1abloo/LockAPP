<Window x:Class="LockCode.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LockCode para Windows" Icon="Assets/LockCode.png" Width="900" Height="620" MinWidth="720" MinHeight="480">
  <DockPanel Margin="18">
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,14">
      <Image DockPanel.Dock="Left" Source="Assets/LockCode.png" Width="48" Height="48" Margin="0,0,10,0"/>
      <Button DockPanel.Dock="Right" Content="Bloquear ahora" Margin="10,4,0,4" Padding="14,6" Click="LockNow_Click"/>
      <StackPanel><TextBlock Text="LockCode" FontSize="26" FontWeight="SemiBold"/><TextBlock Text="Protección de privacidad para Windows"/></StackPanel>
    </DockPanel>
    <TabControl>
      <TabItem Header="Aplicaciones">
        <DockPanel Margin="10">
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Actualizar lista" Padding="12,5" Click="Refresh_Click"/>
            <Button Content="Añadir aplicación manualmente…" Padding="12,5" Margin="8,0,0,0" Click="AddApp_Click"/>
          </StackPanel>
          <ListView x:Name="AppsList"><ListView.ItemTemplate><DataTemplate>
            <CheckBox IsChecked="{Binding IsProtected}" Content="{Binding Name}" ToolTip="{Binding ExecutablePath}" Checked="ProtectionChanged" Unchecked="ProtectionChanged" Padding="4"/>
          </DataTemplate></ListView.ItemTemplate></ListView>
        </DockPanel>
      </TabItem>
      <TabItem Header="Ajustes">
        <StackPanel Margin="18" MaxWidth="600" HorizontalAlignment="Left">
          <CheckBox x:Name="ProtectionEnabled" Content="Protección activada" Margin="0,6" Click="SettingsChanged"/>
          <CheckBox x:Name="BiometricsEnabled" Content="Usar Windows Hello automáticamente" Margin="0,6" Click="SettingsChanged"/>
          <CheckBox x:Name="StartupEnabled" Content="Iniciar LockCode con Windows" Margin="0,6" Click="SettingsChanged"/>
          <TextBlock Text="Volver a bloquear después de estos minutos (0 = al cerrar la aplicación):" Margin="0,14,0,4"/>
          <TextBox x:Name="GraceMinutes" Width="90" HorizontalAlignment="Left" LostFocus="SettingsChanged"/>
          <Button Content="Cambiar código" Padding="12,5" HorizontalAlignment="Left" Margin="0,18,0,0" Click="ChangeCode_Click"/>
        </StackPanel>
      </TabItem>
      <TabItem Header="Registro">
        <DockPanel Margin="10"><Button DockPanel.Dock="Bottom" Content="Borrar registro" Padding="10,5" HorizontalAlignment="Left" Click="ClearAudit_Click"/><ListBox x:Name="AuditList"/></DockPanel>
      </TabItem>
      <TabItem Header="Actualizaciones"><StackPanel Margin="18"><TextBlock Text="LockCode para Windows" FontSize="18" FontWeight="SemiBold"/><TextBlock x:Name="CurrentVersionText" Margin="0,4,0,0"/><TextBlock x:Name="UpdateStatusText" Text="Busca versiones publicadas en el repositorio oficial." Margin="0,8,0,0" TextWrapping="Wrap"/><ProgressBar x:Name="UpdateProgress" Visibility="Collapsed" Height="8" Margin="0,12,0,0" Minimum="0" Maximum="100"/><Button x:Name="UpdateButton" Content="Buscar actualización" Padding="12,5" HorizontalAlignment="Left" Margin="0,12" Click="Updates_Click"/></StackPanel></TabItem>
      <TabItem Header="Ayuda y soporte">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="18" MaxWidth="700" HorizontalAlignment="Left">
            <TextBlock Text="Ayuda y soporte" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Guía práctica para configurar la protección, resolver dudas y contactar con soporte." TextWrapping="Wrap" Margin="0,4,0,14" Foreground="DimGray"/>
            <GroupBox Header="Uso esencial" Margin="0,0,0,10">
              <TextBlock Margin="10" TextWrapping="Wrap" Text="Crea un código, marca las aplicaciones que quieras proteger y deja LockCode activo en el área de notificación. Al detectar una aplicación protegida, la oculta y solicita el código o Windows Hello. Usa «Bloquear ahora» para invalidar inmediatamente los periodos de gracia."/>
            </GroupBox>
            <GroupBox Header="Privacidad y seguridad" Margin="0,0,0,10">
              <TextBlock Margin="10" TextWrapping="Wrap" Text="El registro solo conserva la hora y el resultado de cada intento; nunca guarda códigos, datos biométricos ni nombres de aplicaciones. LockCode es una protección de privacidad best effort y no impide por completo la ejecución de procesos."/>
            </GroupBox>
            <GroupBox Header="Soporte técnico" Margin="0,0,0,10">
              <StackPanel Margin="10">
                <TextBlock TextWrapping="Wrap" Text="Indica las versiones de Windows y LockCode, qué estabas intentando hacer y los pasos para reproducir el problema. No envíes tu código ni información privada."/>
                <Button Content="Escribir a isaaccoria46@gmail.com" HorizontalAlignment="Left" Padding="12,5" Margin="0,10,0,0" Click="SupportEmail_Click"/>
              </StackPanel>
            </GroupBox>
            <GroupBox Header="Proyecto y donación">
              <StackPanel Margin="10">
                <TextBlock TextWrapping="Wrap" Text="LockCode es gratuito y todas sus funciones pueden utilizarse sin donar. Si deseas apoyar voluntariamente su mantenimiento y futuras mejoras, puedes hacerlo mediante PayPal ;)"/>
                <Button Content="Donación voluntaria con PayPal" HorizontalAlignment="Left" Padding="12,5" Margin="0,10,0,0" Click="Donate_Click"/>
                <TextBlock Text="Copyright © 2026 Isaac Silva Jiménez." FontWeight="SemiBold" Margin="0,12,0,0"/>
              </StackPanel>
            </GroupBox>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
